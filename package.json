{
  "name": "@noedgeai-org/doc2x-mcp",
  "version": "0.1.4",
  "description": "Doc2x MCP server (stdio, MCP SDK).",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.30.1",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "doc2x-mcp": "dist/index.js"
  },
  "files": [
    "./dist",
    "./LICENSE",
    "./README.md",
    "./README_EN.md",
    "./scripts/install-skill.sh",
    "./scripts/install-skill.ps1",
    "./scripts/install-skill-winps.ps1",
    "./skills/doc2x-mcp/SKILL.md",
    "./package.json",
    "./icon.png"
  ],
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "skill:install": "sh scripts/install-skill.sh",
    "skill:install:ps": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/install-skill.ps1",
    "skill:install:winps": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-skill-winps.ps1",
    "start": "node dist/index.js",
    "test:unit": "npm run build && node --test test/unit/registerToolsShared.test.js test/unit/materialize.test.js",
    "test:e2e": "npm run build && node --test test/e2e/mcpServer.e2e.test.js",
    "test": "npm run test:unit && npm run test:e2e",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/lodash": "^4.17.23",
    "lodash": "4.18.1",
    "lru-cache": "^11.2.6",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "prettier": "^3.6.2",
    "typescript": "latest"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp": ">=8.4.0"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NoEdgeAI/doc2x-mcp.git"
  },
  "imports": {
    "#config": {
      "types": "./src/config/index.ts",
      "default": "./dist/config/index.js"
    },
    "#errors": {
      "types": "./src/errors/error.ts",
      "default": "./dist/errors/error.js"
    },
    "#errorCodes": {
      "types": "./src/errors/errorCodes.ts",
      "default": "./dist/errors/errorCodes.js"
    },
    "#utils": {
      "types": "./src/shared/utils.ts",
      "default": "./dist/shared/utils.js"
    },
    "#doc2x/*": {
      "types": "./src/doc2x/*.ts",
      "default": "./dist/doc2x/*.js"
    },
    "#mcp/*": {
      "types": "./src/mcp/*.ts",
      "default": "./dist/mcp/*.js"
    }
  },
  "keywords": [
    "doc2x",
    "mcp"
  ],
  "author": "NoEdgeAI",
  "bugs": {
    "url": "https://github.com/NoEdgeAI/doc2x-mcp/issues"
  },
  "homepage": "https://github.com/NoEdgeAI/doc2x-mcp#readme"
}
